apiVersion: apps/v1
kind: Deployment
metadata:
  name: ai-inference
  namespace: ai-service
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ai-inference
  template:
    metadata:
      labels:
        app: ai-inference
    spec:
      # 🚀 [핵심] 윈도우/WSL2의 가상망 문제를 해결하기 위해 호스트 네트워크 직접 사용
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet 
      
      nodeSelector:
        gpu: "true"
      containers:
      - name: inference-container
        image: vllm/vllm-openai:v0.5.5
        command: ["python3", "-m", "vllm.entrypoints.openai.api_server"]
        args:
        - "--model"
        - "/models/Llama-3-Open-Ko-8B-Instruct-preview"
        - "--host"
        - "0.0.0.0"
        - "--port"
        - "8000"
        - "--tensor-parallel-size"
        - "2"
        - "--gpu-memory-utilization"
        - "0.85"
        - "--dtype"
        - "bfloat16"
        - "--max-model-len"
        - "4096"
        - "--trust-remote-code"
        - "--disable-custom-all-reduce"
        ports:
        - containerPort: 8000
        resources:
          requests:
            cpu: "4"
            memory: "24Gi"
            nvidia.com/gpu: 2
          limits:
            cpu: "4"
            memory: "24Gi"
            nvidia.com/gpu: 2
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 300
          periodSeconds: 20
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 200
          periodSeconds: 10
        volumeMounts:
        - name: model-disk
          mountPath: /models
        - name: dshm
          mountPath: /dev/shm
      volumes:
      - name: model-disk
        hostPath:
          path: /mnt/d/AI_Project/models
          type: Directory
      - name: dshm
        emptyDir:
          medium: Memory
          sizeLimit: "16Gi"
