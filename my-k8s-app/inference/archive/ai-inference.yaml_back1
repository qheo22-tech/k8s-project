apiVersion: apps/v1
kind: Deployment
metadata:
  name: ai-inference
  namespace: ai-service
spec:
  replicas: 1
  # 🚀 [수정] GPU 1개 환경에서 기존 파드와 충돌을 방지하기 위해 Recreate 전략 사용
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: ai-inference
  template:
    metadata:
      labels:
        app: ai-inference
    spec:
      # 🚀 [유지] 윈도우/WSL2의 가상망 문제를 해결하기 위해 호스트 네트워크 직접 사용
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet 
      
      nodeSelector:
        gpu: "true"
      containers:
      - name: inference-container
        image: vllm/vllm-openai:v0.5.5
        # [유지] 0번 GPU만 사용하도록 환경 변수 강제 주입
        env:
        - name: CUDA_VISIBLE_DEVICES
          value: "0"
        command: ["python3", "-m", "vllm.entrypoints.openai.api_server"]
        args:
        - "--model"
        - "/models/Llama-3-Open-Ko-8B-Instruct-preview" # 👈 [핵심수정] 원본(Base) 모델 경로로 변경
        - "--host"
        - "0.0.0.0"
        - "--port"
        - "8000"
        - "--tensor-parallel-size"
        - "1"
        - "--gpu-memory-utilization"
        - "0.85"
        - "--dtype"
        - "bfloat16"
        - "--max-model-len"
        - "4096"
        - "--trust-remote-code"
        - "--disable-custom-all-reduce"
        # 🚀 [수정] LoRA 기능을 켜고 학습된 어댑터 경로를 별칭과 함께 지정
        - "--enable-lora"
        - "--lora-modules"
        - "llama3-ko-finetuned=/models/Llama-3-Ko-FineTuned/lora_adapter"
        ports:
        - containerPort: 8000
        resources:
          requests:
            cpu: "4"
            memory: "16Gi"
            nvidia.com/gpu: 1
          limits:
            cpu: "4"
            memory: "16Gi"
            nvidia.com/gpu: 1
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 300
          periodSeconds: 20
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 200
          periodSeconds: 10
        volumeMounts:
        - name: model-disk
          mountPath: /models
        - name: dshm
          mountPath: /dev/shm
      volumes:
      - name: model-disk
        hostPath:
          path: /mnt/d/AI_Project/models
          type: Directory
      - name: dshm
        emptyDir:
          medium: Memory
          sizeLimit: "8Gi"
