apiVersion: apps/v1
kind: Deployment
metadata:
  name: ai-inference
  namespace: ai-service
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ai-inference
  template:
    metadata:
      labels:
        app: ai-inference
    spec:
      # 🚀 WSL2 가상망 문제를 해결하기 위해 호스트 네트워크 사용
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      nodeSelector:
        gpu: "true"
      containers:
      - name: inference-container
        image: vllm/vllm-openai:v0.5.5
        env:
        - name: CUDA_VISIBLE_DEVICES
          value: "0"
        command: ["python3", "-m", "vllm.entrypoints.openai.api_server"]
        args:
        - "--model"
        - "/models/qheo22_final_merged"
        - "--tokenizer"
        - "/models/qheo22_final_merged"
        - "--tokenizer-mode"
        - "auto"
        - "--trust-remote-code"
        - "--gpu-memory-utilization"
        - "0.8"                                   # 👈 메모리 여유를 위해 0.8로 상향
        - "--max-model-len"
        - "2048"                                  # 👈 모델 원래 스펙에 맞게 수정
        - "--enforce-eager"
        - "--dtype"
        - "bfloat16"                              # 👈 데이터 타입 명시
        - "--host"
        - "0.0.0.0"
        - "--port"
        - "8000"
        ports:
        - containerPort: 8000
        resources:
          requests:
            cpu: "4"
            memory: "16Gi"
            nvidia.com/gpu: 1
          limits:
            cpu: "4"
            memory: "16Gi"
            nvidia.com/gpu: 1
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 300
          periodSeconds: 20
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 200
          periodSeconds: 10
        volumeMounts:
        - name: model-disk
          mountPath: /models
        - name: dshm
          mountPath: /dev/shm
      volumes:
      - name: model-disk
        hostPath:
          path: /mnt/d/models
          type: Directory
      - name: dshm
        emptyDir:
          medium: Memory
          sizeLimit:
